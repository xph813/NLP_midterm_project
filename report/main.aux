\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces (a) 维恩图基于 500 抽样：FastText、BERT、Qwen 各自的错样本集合， 交叉部分是“三个模型都错”的真正难样本； (b) 30 条三模型预测不一致样本的人工错因分布： \texttt  {entity-bias} 与 \texttt  {fuzzy-other} 各 12 条（40\,\%），\texttt  {ambiguous} 6 条（20\,\%）。}}{18}{figure.13}\protected@file@percent }
\@writefile{lof}{\contentsline {subfigure}{\numberline{(a)}{\ignorespaces {三模型错例集合维恩图}}}{18}{figure.13}\protected@file@percent }
